{
  "name": "lil-agents-win",
  "version": "1.0.0",
  "description": "Desktop AI pets",
  "main": "dist-electron/main.js",
  "author": "LilAgents",
  "license": "ISC",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.antigravity.lilagents",
    "productName": "LilAgentsWin",
    "directories": {
      "output": "dist-build"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "dir"
      ],
      "publish": null
    },
    "extraResources": [
      {
        "from": "personas",
        "to": "personas",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist",
      "dist-electron",
      "package.json",
      "build"
    ]
  }
}
